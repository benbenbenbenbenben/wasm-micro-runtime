(component
  (type $res-u32 (result u32 (error u32)))
  (type $f-param-type (func (param "x" $res-u32) (result s32)))
  (type $f-ok-type (func (result $res-u32)))
  (type $f-err-type (func (result $res-u32)))
  (core module $m
    (func (export "f_param") (param i32 i32) (result i32)
      local.get 0)
    (func (export "f_ok") (result i32 i32)
      i32.const 0
      i32.const 42)
    (func (export "f_err") (result i32 i32)
      i32.const 1
      i32.const 99)
  )
  (core instance $i (instantiate $m))
  (alias core export $i "f_param" (core func $f_param))
  (alias core export $i "f_ok" (core func $f_ok))
  (alias core export $i "f_err" (core func $f_err))
  (func $g_param (type $f-param-type)
    (canon lift (core func $f_param)))
  (func $g_ok (type $f-ok-type)
    (canon lift (core func $f_ok)))
  (func $g_err (type $f-err-type)
    (canon lift (core func $f_err)))
  (export "g_param" (func $g_param))
  (export "g_ok" (func $g_ok))
  (export "g_err" (func $g_err))
)
