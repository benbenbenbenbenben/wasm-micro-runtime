    (call $source)
    (i32.const 0)
    (i32.load)
    (local.set $lhs)
    (i32.const 20)
    (i32.load)
    (local.set $scalar)
    (i32.const 8)
    (i32.load)
    (local.set $string_len)
    (local.get $lhs)
    (local.get $scalar)
    (i32.add)
    (local.get $string_len)
    (i32.add)
    (i32.const 12)
    (i32.load)
    (i32.load)
    (i32.add)))
